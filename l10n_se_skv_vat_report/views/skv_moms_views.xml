<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_skv_moms_wizard_form" model="ir.ui.view">
        <field name="name">l10n_se_skv_vat_report.wizard.form</field>
        <field name="model">l10n_se_skv_vat_report.wizard</field>
        <field name="arch" type="xml">
            <form string="SKV Momsrapport">
                <field name="overlapping_filings_html" nolabel="1" readonly="1"
                       invisible="not overlapping_filings_html"/>
                <field name="stale_filings_html" nolabel="1" readonly="1"
                       invisible="not stale_filings_html"/>
                <field name="filing_status_html" nolabel="1" readonly="1"
                       invisible="not filing_status_html"/>
                <field name="draft_warning" nolabel="1" readonly="1"
                       invisible="not draft_warning"/>
                <field name="compliance_warnings" nolabel="1" readonly="1"
                       invisible="not compliance_warnings"/>
                <field name="filing_id" invisible="1"/>
                <field name="has_stale_prior" invisible="1"/>
                <field name="has_overlapping_filing" invisible="1"/>
                <group>
                    <group string="Period">
                        <field name="period_type" widget="radio"/>
                        <field name="year" invisible="period_type == 'custom'"/>
                        <field name="quarter" invisible="period_type != 'quarter'"/>
                        <field name="month" invisible="period_type != 'month'"/>
                        <field name="date_from" invisible="period_type != 'custom'"
                               required="period_type == 'custom'"/>
                        <field name="date_to" invisible="period_type != 'custom'"
                               required="period_type == 'custom'"/>
                    </group>
                    <group string="Inställningar">
                        <field name="only_posted"/>
                    </group>
                </group>
                <group invisible="not result_html">
                    <field name="result_html" nolabel="1" colspan="2"/>
                </group>
                <group string="Ångra inlämning" invisible="not filing_id">
                    <field name="cancel_reason" placeholder="Valfri anledning — t.ex. 'Glömd lev.faktura tillkom efter inlämning'"/>
                </group>
                <footer>
                    <button name="action_view_in_browser" type="object"
                            string="Visa i webbläsare" class="btn-secondary"/>
                    <button name="action_view_details" type="object"
                            string="Visa detaljer" class="btn-secondary"
                            help="Lista alla verifikatrader som bidragit till rapporten, grupperade per SKV-ruta"/>
                    <button name="action_view_report" type="object"
                            string="Skriv ut PDF" class="btn-primary"/>

                    <!-- Bokningsknapp: synlig när perioden INTE är inlämnad
                         och det inte finns någon överlapp/drift som blockerar -->
                    <button name="action_create_vat_journal_entry" type="object"
                            string="Skapa momsbokföring + lämna in" class="btn-primary"
                            invisible="filing_id or has_stale_prior or has_overlapping_filing"
                            help="Bokför periodens moms mot 2650 OCH skapar inlämning som fryser värdena. eSKD-filen genereras direkt och kan laddas ner från inlämningen."/>

                    <!-- eSKD-knapp: regenerera om något skulle behöva exporteras
                         igen (filen genereras automatiskt vid bokning, så detta
                         är en fallback) -->
                    <button name="action_export_eskd" type="object"
                            string="Regenerera eSKD-fil" class="btn-secondary"
                            invisible="not filing_id or has_stale_prior or has_overlapping_filing"
                            help="Genererar om XML-filen från frusna inlämningsvärdena. eSKD skapas automatiskt vid 'Skapa momsbokföring' — använd bara denna om filen försvunnit eller behöver bytas ut."/>

                    <!-- Visa filing-knapp -->
                    <button name="action_view_filing" type="object"
                            string="Visa inlämning" class="btn-secondary"
                            invisible="not filing_id"/>

                    <!-- Ångra-knapp -->
                    <button name="action_unfile_period" type="object"
                            string="Ångra inlämning" class="btn-warning"
                            invisible="not filing_id"
                            confirm="Är du säker? Detta reverserar momsverifikatet via Odoos standard reverse_moves och låter dig generera om rapporten."/>

                    <button special="cancel" string="Stäng"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_skv_moms_wizard" model="ir.actions.act_window">
        <field name="name">SKV Momsrapport</field>
        <field name="res_model">l10n_se_skv_vat_report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_skv_section"
              name="Skatteverket"
              parent="account.menu_finance_reports"
              sequence="20"/>

    <menuitem id="menu_skv_moms_wizard"
              name="Momsrapport"
              parent="menu_skv_section"
              action="action_skv_moms_wizard"
              sequence="10"/>

</odoo>
